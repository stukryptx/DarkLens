# MongoDB Configuration
# Replace with your MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/darklens

# Backend Configuration
# Port on which the Node.js Express server will run
PORT=5000

# Frontend Configuration
# Port for the Vite development server
VITE_FRONTEND_PORT=5173

# Base URL for frontend to communicate with the backend API
VITE_API_URL=http://localhost:5000/api
